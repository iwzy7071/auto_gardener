# Copy to config/gardener-relay.env.local or export these variables in your shell.
# Do not commit *.local files.

# Public host or IP of your relay server. Example: 203.0.113.10 or gardener.example.com
GARDENER_RELAY_SERVER_ADDR=YOUR_RELAY_SERVER

# Public base URL used by installers to download packages and provision files.
# Examples: http://203.0.113.10 or https://download.gardener.example.com
GARDENER_RELAY_PUBLIC_BASE_URL=http://YOUR_RELAY_SERVER

# frps control port and per-user public/remote port pools.
GARDENER_RELAY_FRPS_PORT=27000
GARDENER_RELAY_PUBLIC_START=28081
GARDENER_RELAY_PUBLIC_END=28100
GARDENER_RELAY_REMOTE_START=18081
GARDENER_RELAY_REMOTE_END=18100

# Public web/API ports require nginx Basic Auth by default. Set to 0 only for
# trusted/private deployments where direct browser access is more important
# than protecting the relay from anonymous internet users.
# GARDENER_RELAY_REQUIRE_BASIC_AUTH=1

# Gardener itself trusts forwarded host headers from loopback proxies by default.
# If you run Gardener behind a non-loopback Docker/LAN reverse proxy, set this
# in the Gardener process environment, not on the public VPS, to the exact proxy
# IP/CIDR(s), for example:
# AUTO_GARDENER_TRUSTED_PROXIES=10.0.0.0/8,192.168.1.10


# Optional: seed bundled MiniMax/Kimi provider keys into each one-time provision.
# Prefer *_TOKEN_FILE so secrets stay outside shell history and this repo.
# GARDENER_RELAY_MINIMAX_TOKEN_FILE=/etc/gardener-relay/secrets/minimax.token
# GARDENER_RELAY_KIMI_TOKEN_FILE=/etc/gardener-relay/secrets/kimi.token
# Direct env variables are also supported for private deployments:
# GARDENER_RELAY_MINIMAX_TOKEN=sk-...
# GARDENER_RELAY_KIMI_TOKEN=sk-...

# Optional: override published artifact URLs.
# GARDENER_RELAY_WINDOWS_PACKAGE_URL=http://YOUR_RELAY_SERVER/downloads/Gardener-Windows.zip
# GARDENER_RELAY_WINDOWS_INSTALL_SCRIPT_URL=http://YOUR_RELAY_SERVER/downloads/install-gardener.ps1
# GARDENER_RELAY_MAC_INSTALL_SCRIPT_URL=http://YOUR_RELAY_SERVER/downloads/install-gardener-macos.sh
# GARDENER_RELAY_MAC_ARM64_PACKAGE_URL=http://YOUR_RELAY_SERVER/downloads/Gardener-macOS-arm64.tar.gz
# GARDENER_RELAY_MAC_AMD64_PACKAGE_URL=http://YOUR_RELAY_SERVER/downloads/Gardener-macOS-amd64.tar.gz
# GARDENER_RELAY_LINUX_INSTALL_SCRIPT_URL=http://YOUR_RELAY_SERVER/downloads/install-gardener-linux.sh
# GARDENER_RELAY_LINUX_AMD64_PACKAGE_URL=http://YOUR_RELAY_SERVER/downloads/Gardener-Linux-amd64.tar.gz
# GARDENER_RELAY_LINUX_ARM64_PACKAGE_URL=http://YOUR_RELAY_SERVER/downloads/Gardener-Linux-arm64.tar.gz
